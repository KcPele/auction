# =============================================================================
# Frontend environment
# Copy to .env.local for local dev. Never commit .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Server-only. Where Next.js forwards proxied /api/v1/* requests.
# The browser never sees this value — it stays out of the JS bundle.
# Local dev: backend running on :4000.
# Staging:   https://api-staging.kcpele.com
# Prod:      https://api-auction.kcpele.com
API_ORIGIN=http://localhost:4000

# -----------------------------------------------------------------------------
# Optional (uncomment when the corresponding feature is wired)
# -----------------------------------------------------------------------------

# Public app URL. Used for absolute URLs in metadata, OG images, redirects.
# Must match the origin Better Auth sends as `redirectTo` in reset-password emails.
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# WebSocket endpoint for live bids. Bypasses the API proxy on purpose
# (proxying long-lived WS through Next is fragile). Point at the backend
# directly or a dedicated ws subdomain.
# NEXT_PUBLIC_WS_URL=http://localhost:4000

# Sentry / error reporting. Add when wiring `react-error-boundary` to a reporter.
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# Feature flags. Toggle a feature between simulated fixtures and live API
# during the migration phase (see pattern.md → "Migrating simulated screens").
# NEXT_PUBLIC_FEATURE_WALLET_LIVE=false
# NEXT_PUBLIC_FEATURE_AUCTIONS_LIVE=false

# -----------------------------------------------------------------------------
# Conventions
# -----------------------------------------------------------------------------
#
# - Names prefixed with NEXT_PUBLIC_ are inlined into the browser bundle.
#   Use only for non-secret values that must be readable from client code.
# - Names without that prefix are server-only (Next process env, Server
#   Components, route handlers, next.config.ts).
# - Never put secrets, keys, or tokens behind a NEXT_PUBLIC_ prefix.
# =============================================================================
